# Copier ce fichier en .env.local pour le développement local
# Et configurer ces variables sur Vercel pour la production

# Database URL from Neon (production)
DATABASE_URL="postgresql://neondb_owner:REDACTED_DB_PASSWORD@ep-wandering-glitter-ag8ef98y-pooler.c-2.eu-central-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Session secret (32+ caractères aléatoires)
SESSION_SECRET="REDACTED_SESSION_SECRET"

# Vercel Blob Storage token (obtenir depuis Vercel Dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN="your_blob_token_here"

# Secret pour sécuriser les tâches CRON (générer un UUID ou string aléatoire)
# Utilisé par Vercel pour authentifier les appels aux routes CRON
CRON_SECRET="your_cron_secret_here"
