// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  TEXT
  LATEX
}

enum MathMode {
  ADDITION
  SUBTRACTION
  MULTIPLICATION
  DIVISION
}

enum LearningMethod {
  IMMEDIATE
  ANKI
}

enum CardStatus {
  NEW
  LEARNING
  REVIEW
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  displayName        String   // Pseudo de l'utilisateur (généré depuis email)
  isAdmin            Boolean  @default(false)
  reviewedCardsCount Int      @default(0)  // Total number of cards reviewed (increments on each review)

  // Streak fields
  currentStreak      Int      @default(0)
  maxStreak          Int      @default(0)
  lastStreakUpdate   DateTime?

  createdAt          DateTime @default(now())
  decks              Deck[]
  reviews            Review[]
  reviewEvents       ReviewEvent[]
  veryFastMathScores VeryFastMathScore[]
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]

  // Dashboard adoption tracking
  dashboardVersion         String?   // "v1", "v2", ou null (pas encore choisi)
  dashboardChoiceDate      DateTime? // Date du choix initial
  dashboardFeedbackRating  Int?      // Note de 1 à 5 étoiles
  dashboardFeedbackDate    DateTime? // Date du feedback
  dashboardFeedbackGiven   Boolean @default(false) // Évite de redemander

  @@index([currentStreak])
  @@index([maxStreak])
  @@index([dashboardVersion])
  @@index([dashboardChoiceDate])
}

model Deck {
  id             String          @id @default(cuid())
  userId         String
  name           String
  createdAt      DateTime        @default(now())
  learningMethod LearningMethod  @default(IMMEDIATE)

  // Champs pour les decks publics
  isPublic       Boolean  @default(false)     // Indique si le deck est public
  originalDeckId String?                      // R\u00e9f\u00e9rence au deck source (si import\u00e9)
  importCount    Int      @default(0)         // Nombre d'importations

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards          Card[]
  originalDeck   Deck?    @relation("DeckImports", fields: [originalDeckId], references: [id], onDelete: Cascade)
  importedBy     Deck[]   @relation("DeckImports")

  @@index([userId])
  @@index([originalDeckId])
  @@index([isPublic])
}

model Card {
  id           String      @id @default(cuid())
  deckId       String
  front        String      @db.Text
  back         String      @db.Text
  frontType    ContentType @default(TEXT)
  backType     ContentType @default(TEXT)
  frontImage   String?
  backImage    String?
  order        Int
  deck         Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews      Review[]
  reviewEvents ReviewEvent[]

  @@index([deckId])
  @@index([deckId, order])
}

model Review {
  id          String    @id @default(cuid())
  cardId      String
  userId      String

  // Statistics
  reps        Int       @default(0)        // Total number of reviews
  againCount  Int       @default(0)        // Number of "Again" responses
  hardCount   Int       @default(0)        // Number of "Hard" responses
  goodCount   Int       @default(0)        // Number of "Good" responses
  easyCount   Int       @default(0)        // Number of "Easy" responses
  lastReview  DateTime?                    // Last review timestamp

  // Anki-specific fields
  interval    Int?                         // Current interval in days (Anki)
  nextReview  DateTime?                    // Next review date (Anki)
  easeFactor  Float     @default(2.5)      // Ease factor (Anki)
  status      CardStatus @default(NEW)     // Card status (Anki)

  // Metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      ReviewEvent[]

  @@unique([cardId, userId])
  @@index([userId])
  @@index([nextReview])
}

model AppSettings {
  id              String @id @default(cuid())
  maxDecksPerUser Int    @default(10)
  maxTotalUsers   Int    @default(5)
  updatedAt       DateTime @updatedAt
}

model ReviewEvent {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  cardId    String
  rating    String   // 'again', 'hard', 'good', 'easy'
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewId])
}

model VeryFastMathScore {
  id        String   @id @default(cuid())
  userId    String
  mode      MathMode
  score     Int      // Nombre d'opérations réussies
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode])
  @@index([mode, createdAt])
  @@index([mode, score])
}

model OrphanedImage {
  id          String   @id @default(cuid())
  imagePath   String   @unique
  createdAt   DateTime @default(now())
  retryCount  Int      @default(0)
  lastError   String?  @db.Text

  @@index([retryCount])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.Text // Token hashé
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_SIGNUP
  USER_DELETE
  DECK_CREATE
  DECK_UPDATE
  DECK_DELETE
  DECK_PUBLISH
  DECK_UNPUBLISH
  CARD_CREATE
  CARD_UPDATE
  CARD_DELETE
  SETTINGS_UPDATE
  ADMIN_ACTION
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?     // Nullable pour les actions sans utilisateur authentifié
  action      AuditAction
  targetType  String?     // Type de ressource (deck, card, user, etc.)
  targetId    String?     // ID de la ressource
  ipAddress   String?
  userAgent   String?     @db.Text
  metadata    String?     @db.Text // JSON stringifié pour données additionnelles
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}
