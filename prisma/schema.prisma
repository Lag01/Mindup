// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  TEXT
  LATEX
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  displayName        String   // Pseudo de l'utilisateur (généré depuis email)
  isAdmin            Boolean  @default(false)
  reviewedCardsCount Int      @default(0)  // Total number of cards reviewed (increments on each review)
  createdAt          DateTime @default(now())
  decks              Deck[]
  reviews            Review[]
  reviewEvents       ReviewEvent[]
}

model Deck {
  id             String   @id @default(cuid())
  userId         String
  name           String
  createdAt      DateTime @default(now())

  // Champs pour les decks publics
  isPublic       Boolean  @default(false)     // Indique si le deck est public
  originalDeckId String?                      // R\u00e9f\u00e9rence au deck source (si import\u00e9)
  importCount    Int      @default(0)         // Nombre d'importations

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards          Card[]
  originalDeck   Deck?    @relation("DeckImports", fields: [originalDeckId], references: [id], onDelete: Cascade)
  importedBy     Deck[]   @relation("DeckImports")

  @@index([userId])
  @@index([originalDeckId])
  @@index([isPublic])
}

model Card {
  id           String      @id @default(cuid())
  deckId       String
  front        String      @db.Text
  back         String      @db.Text
  frontType    ContentType @default(TEXT)
  backType     ContentType @default(TEXT)
  frontImage   String?
  backImage    String?
  order        Int
  deck         Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews      Review[]
  reviewEvents ReviewEvent[]

  @@index([deckId])
}

model Review {
  id          String    @id @default(cuid())
  cardId      String
  userId      String

  // Statistics
  reps        Int       @default(0)        // Total number of reviews
  againCount  Int       @default(0)        // Number of "Again" responses
  hardCount   Int       @default(0)        // Number of "Hard" responses
  goodCount   Int       @default(0)        // Number of "Good" responses
  easyCount   Int       @default(0)        // Number of "Easy" responses
  lastReview  DateTime?                    // Last review timestamp

  // Metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      ReviewEvent[]

  @@unique([cardId, userId])
  @@index([userId])
}

model AppSettings {
  id              String @id @default(cuid())
  maxDecksPerUser Int    @default(10)
  maxTotalUsers   Int    @default(5)
  updatedAt       DateTime @updatedAt
}

model ReviewEvent {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  cardId    String
  rating    String   // 'again', 'hard', 'good', 'easy'
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewId])
}
