# Base de données PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Secret pour les sessions JWT (générer avec : openssl rand -hex 32)
SESSION_SECRET="your-secret-key-here-minimum-32-chars"

# Secret pour les jobs cron (générer un UUID ou chaîne aléatoire)
CRON_SECRET="generate-a-random-uuid-or-string"

# Vercel Blob Storage (obtenir depuis Vercel Dashboard > Storage > Blob)
# Format du token : préfixe "vercel_blob_rw_" suivi d'une longue chaîne alphanumérique
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token-from-dashboard"
