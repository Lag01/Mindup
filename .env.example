# Database URL from Neon
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Secret for session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET="your-secret-key-here-min-32-chars"

# Cron job protection (generate a random UUID or string)
CRON_SECRET="generate-a-random-uuid-or-string"
